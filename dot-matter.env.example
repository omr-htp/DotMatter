# Runtime overrides loaded by dot-matter.service
# Keep dot-matter.env and dot-matter-aot.env identical unless you intentionally
# need different behavior when switching between the fast and AOT services.
ASPNETCORE_URLS=http://0.0.0.0:5000
Controller__Commissioning__SharedFabricName=DotMatter
Controller__Registry__BasePath=/var/lib/.dot-matter/fabrics
Controller__Otbr__CommandPath=ot-ctl
Controller__Otbr__SudoCommand=sudo
Controller__Security__ApiKey=replace-with-a-long-random-value

# Optional operator-only endpoints on a trusted LAN:
# Controller__Api__EnableOpenApi=true
# Controller__Diagnostics__EnableDetailedRuntimeEndpoint=true
# Controller__MatterLog__EnableSensitiveDiagnostics=true

# Optional trusted-LAN development override:
# DOTNET_ENVIRONMENT=Development
# Controller__Security__RequireApiKey=false
