{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      }
    }
  },
  "Controller": {
    "Security": {
      "RequireApiKey": true,
      "HeaderName": "X-API-Key",
      "AllowedCorsOrigins": []
    },
    "Api": {
      "RateLimitPermitLimit": 60,
      "RateLimitWindow": "00:01:00",
      "RateLimitQueueLimit": 5,
      "SseClientBufferCapacity": 100,
      "CommandTimeout": "00:00:10",
      "EnableOpenApi": false
    },
    "Commissioning": {
      "DefaultFabricNamePrefix": "device",
      "SharedFabricName": "DotMatter",
      "FollowUpConnectTimeout": "00:00:30"
    },
    "Diagnostics": {
      "EnableDetailedRuntimeEndpoint": false
    },
    "Registry": {
      "BasePath": "/var/lib/.dot-matter/fabrics"
    },
    "SessionRecovery": {
      "SubscriptionStaleThreshold": "00:01:30",
      "StartupConnectTimeout": "00:00:15",
      "EndpointDiscoveryTimeout": "00:00:10",
      "StateReadTimeout": "00:00:10",
      "SubscriptionSetupTimeout": "00:00:10",
      "MonitoringLoopDelay": "00:00:01",
      "BackgroundShutdownTimeout": "00:00:10"
    },
    "Otbr": {
      "EnableSrpServerOnStartup": true,
      "CommandPath": "ot-ctl",
      "SudoCommand": "sudo",
      "ThreadIpDiscoveryMaxAttempts": 10,
      "ThreadIpDiscoveryDelay": "00:00:02"
    },
    "MatterLog": {
      "EnableSensitiveDiagnostics": false,
      "MaxRenderedBytes": 32
    }
  }
}
